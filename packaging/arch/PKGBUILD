pkgname=cockpit-cli
pkgver=0.1.0
pkgrel=1
pkgdesc="Keyboard-first TUI platform for developer workspaces"
arch=('any')
url="https://github.com/DamienDrash/cockpit_cli"
license=('MIT')
depends=('python' 'python-pyyaml' 'python-textual' 'python-sqlalchemy')
makedepends=('python-build' 'python-hatchling' 'python-installer' 'python-wheel')
source=("git+https://github.com/DamienDrash/cockpit_cli.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/cockpit_cli"
  git describe --tags --always | sed 's/^v//;s/-/+/g'
}

build() {
  cd "$srcdir/cockpit_cli"
  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/cockpit_cli"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
